# ============================================================
#  eBPF 网络攻击检测系统 - Git 忽略规则
#  防止垃圾文件和临时文件被提交到仓库
# ============================================================

# --- Python 临时文件 ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# --- 运行时数据库 ---
*.db
backend/data/

# --- IDE / 编辑器配置 ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker 环境变量（如果有） ---
.env

# --- 系统文件 ---
*.log
